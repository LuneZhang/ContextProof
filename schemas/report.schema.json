{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contextproof.dev/schemas/report.schema.json",
  "title": "ContextProof Report",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "root",
    "project_mode",
    "confidence_state",
    "static_context_score",
    "benchmark_evidence",
    "summary",
    "change_detection",
    "context_files",
    "commands",
    "findings",
    "recommendations"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "root": { "type": "string" },
    "project_mode": {
      "type": "string",
      "enum": ["existing_project", "new_project", "migration_project"]
    },
    "confidence_state": {
      "type": "string",
      "enum": [
        "static_only",
        "static_with_insufficient_benchmark",
        "static_with_mixed_benchmark",
        "static_with_directional_benchmark",
        "static_with_supported_benchmark"
      ]
    },
    "static_context_score": {
      "type": "object",
      "required": ["total", "dimensions"],
      "properties": {
        "total": { "type": "integer", "minimum": 0, "maximum": 100 },
        "dimensions": {
          "type": "object",
          "required": [
            "discoverability",
            "actionability",
            "minimality",
            "consistency",
            "safety",
            "workflow_fit"
          ],
          "properties": {
            "discoverability": { "type": "integer", "minimum": 0, "maximum": 100 },
            "actionability": { "type": "integer", "minimum": 0, "maximum": 100 },
            "minimality": { "type": "integer", "minimum": 0, "maximum": 100 },
            "consistency": { "type": "integer", "minimum": 0, "maximum": 100 },
            "safety": { "type": "integer", "minimum": 0, "maximum": 100 },
            "workflow_fit": { "type": "integer", "minimum": 0, "maximum": 100 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "benchmark_evidence": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "not_provided",
            "insufficient",
            "mixed",
            "directional_positive",
            "directional_negative",
            "supported_positive",
            "supported_negative"
          ]
        },
        "reason": { "type": "string" },
        "target_variant": { "type": "string" },
        "paired_groups": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "benchmark_summary": { "type": "object" },
    "baseline_delta": {
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "baseline_report": { "type": "string" },
        "score_delta": { "type": "integer" },
        "baseline_score": { "type": "integer" },
        "current_score": { "type": "integer" },
        "new_finding_count": { "type": "integer", "minimum": 0 },
        "resolved_finding_count": { "type": "integer", "minimum": 0 },
        "unchanged_finding_count": { "type": "integer", "minimum": 0 },
        "new_findings": { "type": "array" },
        "resolved_findings": { "type": "array" }
      },
      "additionalProperties": true
    },
    "change_detection": {
      "type": "object",
      "required": ["status", "changed_context_files"],
      "properties": {
        "status": { "type": "string" },
        "reason": { "type": "string" },
        "source": { "type": "string" },
        "base_ref": { "type": ["string", "null"] },
        "changed_files": { "type": "array", "items": { "type": "string" } },
        "changed_context_files": { "type": "array", "items": { "type": "string" } },
        "changed_context_file_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "summary": { "type": "object" },
    "context_files": { "type": "array" },
    "commands": { "type": "array" },
    "findings": { "type": "array" },
    "recommendations": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
